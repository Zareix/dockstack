{
  "name": "dockstack",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run --bun vite dev --port 3000",
    "build": "bun run --bun vite build",
    "preview": "bun run --bun vite preview",
    "test": "bun test",
    "lint": "eslint --fix",
    "format": "prettier --write .",
    "check": "bun run lint && bun run format",
    "db:generate": "bunx drizzle-kit generate",
    "auth:generate": "bunx --bun @better-auth/cli generate --config src/lib/auth/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth-ui/core": "^1.6.8",
    "@better-auth-ui/react": "^1.6.8",
    "@fontsource-variable/geist": "^5.2.9",
    "@monaco-editor/react": "^4.7.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-virtual": "^3.13.26",
    "@tanstack/router-plugin": "^1.168.11",
    "@types/dockerode-compose": "^1.4.2",
    "base-ui": "^0.0.294",
    "better-auth": "^1.6.11",
    "bowser": "^2.14.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dockerode": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.54.0",
    "monaco-yaml": "^5.5.0",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.260522-beta",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
