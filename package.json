{
  "name": "dockstack",
  "version": "0.11.8",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "bun run --bun vite dev --port 3000",
    "build": "bun run --bun vite build",
    "preview": "bun run --bun vite preview",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "check": "bun run format && bun run lint:fix",
    "db:generate": "bunx drizzle-kit generate",
    "auth:generate": "bunx --bun @better-auth/cli generate --config src/lib/auth/index.ts --output src/db/schema/auth-schema.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
