{
  "language_servers": ["!biome", "!eslint", "..."],
  "languages": {
    "JavaScript": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.removeUnusedImports": true,
        "source.fixAll.oxc": true,
        "sourceAll.organizeImports": true,
      },
    },
    "TypeScript": {
      "language_servers": ["tsgo", "oxlint"],
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.removeUnusedImports": true,
        "source.fixAll.oxc": true,
        "sourceAll.organizeImports": true,
      },
    },
    "TSX": {
      "language_servers": ["tsgo", "oxlint"],
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.removeUnusedImports": true,
        "source.fixAll.oxc": true,
        "sourceAll.organizeImports": true,
      },
    },
    "JSON": { "formatter": "prettier" },
    "JSONC": { "formatter": "prettier" },
    "CSS": { "formatter": "prettier" },
  },
}
