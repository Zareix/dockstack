{
  "language_servers": ["!biome", "!eslint", "..."],
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true,
        "sourceAll.": true
      }
    },
    "TypeScript": {
      "language_servers": ["tsgo", "oxlint", "oxfmt", "tailwindcss-language-server"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "TSX": {
      "language_servers": ["tsgo", "oxlint", "oxfmt", "tailwindcss-language-server"],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ],
      "code_actions_on_format": {
        "source.fixAll.oxc": true
      }
    },
    "JSON": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "JSONC": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "CSS": {
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    }
  }
}
